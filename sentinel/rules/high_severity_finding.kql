// Rule:     HIGH Severity Finding Detected
// Tactic:   Initial Access / Impact
// Severity: High
// Run:      Every 1 hour

OpenShieldFindings_CL
| where TimeGenerated >= ago(1h)
| where Severity_s in ("High", "Critical")
| summarize
    FindingCount = count(),
    FirstSeen    = min(TimeGenerated),
    LastSeen     = max(TimeGenerated)
  by RuleName_s, Severity_s, ResourceName_s, ResourceGroup
| where FindingCount >= 1
| order by Severity_s asc, LastSeen desc
